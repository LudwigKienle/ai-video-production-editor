# AI Video Production Editor environment template
#
# Copy this file to .env.local for local development. Keep real values out of
# git. The desktop app can also store user provider keys locally from the UI.

# Optional client-side docs/support helpers
VITE_GEMINI_API_KEY=<gemini-api-key>
VITE_GEMINI_MODEL=gemini-2.5-flash
VITE_ADOBE_PORTFOLIO_URL=https://yourname.myportfolio.com
VITE_BRAVE_SEARCH_API_KEY=<brave-search-api-key>

# Optional Supabase-backed portal/auth/collaboration
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=<supabase-anon-key>
VITE_HOCUSPOCUS_URL=wss://your-hocuspocus-server.example
VITE_HOCUSPOCUS_TOKEN=<hocuspocus-token>

# Optional hosted API routes and BYOK proxy
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<supabase-service-role-key>
BYOK_VAULT_SECRET=<long-random-secret>
BYOK_DAILY_CAP_DEFAULT_USD=25
BYOK_HARD_STOP_DEFAULT=true

# Optional Stripe billing
STRIPE_SECRET_KEY=<stripe-secret-key>
STRIPE_WEBHOOK_SECRET=<stripe-webhook-secret>
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=<stripe-publishable-key>
NEXT_PUBLIC_APP_URL=http://localhost:5173
APP_URL=http://localhost:5173

# Optional Stripe Price ID overrides used by /api/stripe/*
STRIPE_PRICE_LITE=<stripe-price-id>
STRIPE_PRICE_STARTER=<stripe-price-id>
STRIPE_PRICE_PRO=<stripe-price-id>
STRIPE_PRICE_STUDIO=<stripe-price-id>
STRIPE_PRICE_BYOK=<stripe-price-id>
STRIPE_PRICE_CREDITS_1000=<stripe-price-id>
STRIPE_PRICE_CREDITS_2500=<stripe-price-id>
STRIPE_PRICE_CREDITS_5000=<stripe-price-id>
STRIPE_PRICE_CREDITS_10000=<stripe-price-id>

# Optional macOS signing/notarization for release builds
APPLE_ID=you@example.com
APPLE_APP_SPECIFIC_PASSWORD=<apple-app-specific-password>
APPLE_TEAM_ID=<apple-team-id>
NOTARYTOOL_KEYCHAIN_PROFILE=<notarytool-keychain-profile>
